---
interface ImageEntry {
  src: ImageMetadata;
  alt: string;
}

interface Props {
  index: number;
  src: ImageEntry;
  gt: ImageEntry;
  view3d: ImageEntry;
  ours: ImageEntry;
  qwen: ImageEntry;
  nanoBanana: ImageEntry;
}

const { index, src, gt, view3d, ours, qwen, nanoBanana } = Astro.props;

import { Image } from "astro:assets";

const topRow = [
  { ...src, label: "Source", highlight: false },
  { ...gt, label: "Ground Truth", highlight: false },
  { ...view3d, label: "3D View", highlight: false },
];

const bottomRow = [
  { ...ours, label: "Ours ★", highlight: true },
  { ...qwen, label: "Qwen-Image-2.0-Pro", highlight: false },
  { ...nanoBanana, label: "Nano Banana Pro", highlight: false },
];
---

<div class="w-full space-y-1">
  <div class="grid grid-cols-3 gap-1.5">
    {topRow.map(({ src, alt, label }) => (
      <div class="flex flex-col gap-1">
        <Image src={src} alt={alt} class="w-full rounded object-cover aspect-square" />
        <span class="text-center text-xs text-zinc-500 dark:text-zinc-400">{label}</span>
      </div>
    ))}
  </div>
  <div class="grid grid-cols-3 gap-1.5">
    {bottomRow.map(({ src, alt, label, highlight }) => (
      <div class="flex flex-col gap-1">
        <div class={`rounded overflow-hidden ${highlight ? "ring-2 ring-blue-500 dark:ring-blue-400" : ""}`}>
          <Image src={src} alt={alt} class="w-full object-cover aspect-square" />
        </div>
        <span class={`text-center text-xs ${highlight ? "font-semibold text-blue-600 dark:text-blue-400" : "text-zinc-500 dark:text-zinc-400"}`}>{label}</span>
      </div>
    ))}
  </div>
</div>
